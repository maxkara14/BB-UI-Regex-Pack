{
    "id": "f652a6ef-df6b-4353-a80e-406fde5626b2",
    "scriptName": "[BB] clocks",
    "findRegex": "/<info>\\s*(.*?)\\s*\\|\\s*(.*?)\\s*\\|\\s*(.*?)\\s*\\|\\s*(.*?)\\s*\\|\\s*(.*?)\\s*<\\/info>/g",
    "replaceString": "<style>\n.elegant-clock-wrap {\n  background: linear-gradient(135deg, rgba(25, 15, 15, 0.7), rgba(10, 5, 5, 0.7));\n  border: 1px solid rgba(212, 175, 55, 0.2);\n  border-left: 3px solid #d4af37;\n  border-radius: 6px;\n  padding: 10px 18px;\n  margin: 20px 0;\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  box-shadow: 0 4px 15px rgba(0,0,0,0.4), inset 0 0 10px rgba(212, 175, 55, 0.05);\n  font-family: 'Georgia', serif;\n  flex-wrap: wrap;\n}\n.ec-time {\n  font-size: 1.6em;\n  color: #fef08a;\n  letter-spacing: 1px;\n  text-shadow: 0 0 10px rgba(212, 175, 55, 0.4);\n}\n.ec-divider {\n  width: 1px;\n  height: 32px;\n  background: linear-gradient(to bottom, transparent, rgba(212, 175, 55, 0.5), transparent);\n}\n.ec-details { display: flex; flex-direction: column; gap: 4px; }\n.ec-loc {\n  font-size: 0.85em;\n  font-weight: bold;\n  color: #fca5a5;\n  letter-spacing: 1px;\n  text-transform: uppercase;\n}\n.ec-sub {\n  font-size: 0.75em;\n  color: #d1d5db;\n  letter-spacing: 1px;\n}\n.ec-dot { color: #d4af37; margin: 0 6px; }\n</style>\n<div class=\"elegant-clock-wrap\">\n  <div class=\"ec-time\">$5</div>\n  <div class=\"ec-divider\"></div>\n  <div class=\"ec-details\">\n    <span class=\"ec-loc\">$3</span>\n    <div class=\"ec-sub\">\n      <span>$1 ($2)</span> <span class=\"ec-dot\">•</span> <span>$4</span>\n    </div>\n  </div>\n</div>",
    "trimStrings": [],
    "placement": [
        1,
        2,
        6
    ],
    "disabled": false,
