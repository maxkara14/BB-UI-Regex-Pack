{
    "id": "bf791553-803d-465e-b41a-33f9fb545b1b",
    "scriptName": "[BB] phone - DM",
    "findRegex": "/::KG_CHAT_START::\\s*(?:Time:\\s*([^\\n]*)\\s*)?(?:Date:\\s*([^\\n]*)\\s*)?(?:Notif:\\s*([^\\n]*)\\s*)?(?:Mood_Main:\\s*([^\\n]*)\\s*)?(?:Mood_Color:\\s*([^\\n]*)\\s*)?(?:Thought:\\s*([^\\n]*)\\s*)?(?:Moodlet_1:\\s*([^|\\n]+?)\\s*\\|\\s*([^|\\n]+?)\\s*\\|\\s*([^\\n]*)\\s*)?(?:Moodlet_2:\\s*([^|\\n]+?)\\s*\\|\\s*([^|\\n]+?)\\s*\\|\\s*([^\\n]*)\\s*)?(?:Moodlet_3:\\s*([^|\\n]+?)\\s*\\|\\s*([^|\\n]+?)\\s*\\|\\s*([^\\n]*)\\s*)?(?:Moodlet_4:\\s*([^|\\n]+?)\\s*\\|\\s*([^|\\n]+?)\\s*\\|\\s*([^\\n]*)\\s*)?(?:Need_Energy:\\s*(-?\\d+)[^\\n]*\\s*)?(?:Need_Hunger:\\s*(-?\\d+)[^\\n]*\\s*)?(?:Need_Social:\\s*(-?\\d+)[^\\n]*\\s*)?(?:Need_Comfort:\\s*(-?\\d+)[^\\n]*\\s*)?(?:Outfit_Head:\\s*([^\\n]*)\\s*)?(?:Outfit_Top:\\s*([^\\n]*)\\s*)?(?:Outfit_Legs:\\s*([^\\n]*)\\s*)?(?:Outfit_Shoes:\\s*([^\\n]*)\\s*)?(?:Outfit_Acc:\\s*([^\\n]*)\\s*)?(?:Inv_Hand:\\s*([^\\n]*)\\s*)?(?:Inv_Bag:\\s*([^\\n]*)\\s*)?(?:Chat_With:\\s*([^\\n]*)\\s*)?(?:Initials:\\s*([^\\n]*)\\s*)?(?:Nick:\\s*([^\\n]*)\\s*)?(?:Status:\\s*([^\\n]*)\\s*)?(?:M1_From:\\s*([^\\n]*)\\s*)?(?:M1_Text:\\s*([^\\n]*)\\s*)?(?:M2_From:\\s*([^\\n]*)\\s*)?(?:M2_Text:\\s*([^\\n]*)\\s*)?(?:M3_From:\\s*([^\\n]*)\\s*)?(?:M3_Text:\\s*([^\\n]*)\\s*)?(?:M4_From:\\s*([^\\n]*)\\s*)?(?:M4_Text:\\s*([^\\n]*)\\s*)?(?:Battery:\\s*(-?\\d+)[^\\n]*\\s*)?[\\s\\S]*?::KG_CHAT_END::/g",
    "replaceString": "<style>\n@keyframes battShine { 0% { left: -20px; } 20%, 100% { left: 100%; } }\n@keyframes redBlink { 0%, 90%, 100% { background: #050505; box-shadow: inset 0 0 4px rgba(255,255,255,0.15); } 95% { background: #ef4444; box-shadow: 0 0 8px #ef4444; } }\n@keyframes ringBell { 0%, 80%, 100% { transform: rotate(0); filter: blur(0); } 82%, 86%, 90%, 94%, 98% { transform: rotate(-20deg); filter: blur(0.5px) drop-shadow(2px 0 0 rgba(252,165,165,0.6)); } 84%, 88%, 92%, 96% { transform: rotate(20deg); filter: blur(0.5px) drop-shadow(-2px 0 0 rgba(252,165,165,0.6)); } }\n@keyframes kgPulse { 0%,100%{opacity:0.5; transform:translateY(0);} 50%{opacity:1; transform:translateY(-5px);} }\n@keyframes gemPulse { 0%, 100% { box-shadow: 0 0 10px var(--c, #d4af37), inset 0 0 5px var(--c, #d4af37); transform: scale(1); } 50% { box-shadow: 0 0 25px var(--c, #d4af37), inset 0 0 12px var(--c, #d4af37); transform: scale(1.05); filter: brightness(1.2); } }\n@keyframes tsubaSpin { 100% { transform: translate(-50%, -50%) rotate(360deg); } }\n.kg-smart { position:relative; width:340px; height:640px; margin:20px auto; background:#070709; border-radius:42px; border:8px solid #1a1a1e; box-shadow:0 25px 60px rgba(0,0,0,0.8); overflow:hidden; font-family:-apple-system,sans-serif; color:#fff; user-select:none; }\n.kg-chk { display:none; }\n.kg-screen { position:absolute; inset:0; overflow:hidden; }\n.kg-scroll { overflow-y:auto; scrollbar-width:none; -ms-overflow-style:none; }\n.kg-scroll::-webkit-scrollbar { display:none; }\n.kg-topbar { position:absolute; top:0; left:0; right:0; height:45px; display:flex; justify-content:space-between; align-items:center; padding:0 22px; z-index:100; font-size:12px; font-weight:700; text-shadow:0 1px 3px rgba(0,0,0,0.8); pointer-events:none; }\n.kg-notch { position:absolute; top:0; left:50%; transform:translateX(-50%); width:110px; height:28px; background:#000; border-radius:0 0 14px 14px; display:flex; justify-content:center; align-items:center; z-index:101; border-bottom:1px solid #1a1a1e; }\n.kg-lens { width:10px; height:10px; background:#050505; border-radius:50%; border:1px solid #111; box-shadow:inset 0 0 4px rgba(255,255,255,0.15); animation: redBlink 4s infinite; }\n.kg-batt-wrap { display:flex; align-items:center; gap:5px; pointer-events:auto; }\n.kg-batt-icon { width:22px; height:11px; border:1px solid rgba(255,255,255,0.6); border-radius:3px; padding:1px; position:relative; background:rgba(0,0,0,0.5); }\n.kg-batt-icon::after { content:''; position:absolute; right:-3px; top:2px; width:2px; height:4px; background:rgba(255,255,255,0.6); border-radius:0 1px 1px 0; }\n.kg-batt-fill { height:100%; background:linear-gradient(90deg, #10b981, #34d399); border-radius:1px; position:relative; overflow:hidden; }\n.kg-batt-fill::after { content:''; position:absolute; top:0; left:-20px; width:20px; height:100%; background:linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent); animation:battShine 3s infinite; }\n.kg-layer-app { position:absolute; inset:0; background:#070709; display:flex; flex-direction:column; padding-top:45px; z-index:10; }\n.kg-shade-handle { position:absolute; top:28px; left:50%; transform:translateX(-50%); width:80px; height:15px; display:flex; justify-content:center; align-items:center; cursor:pointer; z-index:15; }\n.kg-shade-handle::after { content:''; width:35px; height:4px; background:rgba(255,255,255,0.2); border-radius:2px; }\n.kg-layer-shade { position:absolute; inset:0; background:rgba(10,10,15,0.95); backdrop-filter:blur(15px); z-index:30; transform:translateY(-100%); transition:transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1); display:flex; flex-direction:column; padding-top:45px; }\n.kg-chk-shade:checked ~ .kg-screen .kg-layer-shade { transform:translateY(0); }\n.kg-shade-close-handle { display:flex; justify-content:center; align-items:center; width:100%; height:30px; cursor:pointer; flex-shrink:0; margin-bottom:10px; }\n.kg-shade-close-handle::after { content:''; width:40px; height:5px; background:rgba(255,255,255,0.4); border-radius:3px; }\n.kg-shade-content { flex:1; padding:0 15px 15px 15px; display:flex; flex-direction:column; gap:15px; }\n.kg-layer-lock { position:absolute; inset:0; background:linear-gradient(to bottom, rgba(10,10,15,0.3), #070709), url('https://images2.imgbox.com/cd/d4/j6VOin3X_o.png') center/cover; z-index:40; display:flex; flex-direction:column; align-items:center; padding-top:80px; transition:transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease; }\n.kg-chk-lock:checked ~ .kg-screen .kg-layer-lock { transform:translateY(-100%); opacity:0; pointer-events:none; }\n.kg-l-time { font-size:70px; font-weight:200; line-height:1; text-shadow:0 4px 10px rgba(0,0,0,0.8); }\n.kg-l-date { font-size:14px; font-weight:600; color:#d4af37; text-transform:uppercase; margin-top:5px; text-shadow:0 2px 4px rgba(0,0,0,0.8); }\n.kg-l-notif { background:rgba(20,20,25,0.7); border:1px solid rgba(255,255,255,0.1); border-radius:16px; padding:14px 16px; width:85%; margin-top:35px; backdrop-filter:blur(5px); }\n.kg-notif-head { display:flex; align-items:center; gap:8px; margin-bottom:6px; }\n.kg-bell { width:14px; height:14px; color:#fca5a5; transform-origin:top center; animation:ringBell 4s infinite; }\n.kg-unlock-btn { position:absolute; bottom:40px; font-size:11px; font-weight:600; color:rgba(255,255,255,0.6); text-transform:uppercase; letter-spacing:2px; cursor:pointer; animation:kgPulse 2s infinite; padding:10px; text-shadow:0 1px 2px #000; }\n.kg-w-mood { background:rgba(20,15,20,0.8); border-radius:20px; padding:16px; border:1px solid rgba(255,255,255,0.05); border-left:4px solid var(--c, #d4af37); display:flex; flex-direction:column; gap:14px; }\n.kg-m-head { display:flex; align-items:flex-start; gap:14px; }\n.kg-gem { width:34px; height:34px; border-radius:50%; border:3px solid var(--c, #d4af37); background:#111; flex-shrink:0; position:relative; animation:gemPulse 4s infinite ease-in-out; }\n.kg-gem::after { content: ''; width: 12px; height: 4px; background: #000; border-radius: 2px; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); animation: tsubaSpin 8s linear infinite; }\n.kg-m-titles { flex:1; min-width:0; }\n.kg-m-main { font-size:14px; font-weight:800; color:var(--c, #d4af37); text-transform:uppercase; letter-spacing:1px; overflow-wrap:break-word; word-wrap:break-word; }\n.kg-m-sub { font-size:11px; color:#a1a1aa; font-style:italic; margin-top:4px; line-height:1.3; }\n.kg-m-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; }\n.kg-m-card { background:rgba(0,0,0,0.5); padding:10px; border-radius:10px; display:flex; flex-direction:column; min-width:0; border:1px solid rgba(255,255,255,0.03); transition:all 0.3s ease; cursor:default; }\n.kg-m-card:hover { transform:translateY(-3px); box-shadow:0 6px 15px rgba(0,0,0,0.6); border-color:rgba(212,175,55,0.4); background:rgba(30,20,20,0.9); }\n.kg-m-card:hover .kg-mc-emoji { transform:scale(1.3) rotate(10deg); filter:drop-shadow(0 0 5px rgba(212,175,55,0.4)); }\n.kg-mc-top { display:flex; justify-content:space-between; align-items:center; margin-bottom:4px; width:100%; overflow:hidden; }\n.kg-mc-title { font-size:9px; font-weight:800; color:#d4af37; text-transform:uppercase; letter-spacing:0.5px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; flex:1; margin-right:4px; }\n.kg-mc-emoji { flex-shrink:0; font-size:13px; transition:transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }\n.kg-mc-txt { font-size:11px; color:#d4d4d8; line-height:1.3; overflow-wrap:break-word; word-wrap:break-word; hyphens:auto; }\n.kg-w-needs { background:rgba(20,15,20,0.8); border-radius:20px; padding:16px; border:1px solid rgba(255,255,255,0.05); display:flex; flex-direction:column; gap:12px; }\n.kg-n-row { display:flex; align-items:center; gap:12px; }\n.kg-n-label { font-size:10px; font-weight:800; color:#a1a1aa; width:65px; text-transform:uppercase; }\n.kg-n-track { flex:1; height:6px; background:rgba(0,0,0,0.5); border-radius:3px; }\n.kg-n-fill { height:100%; border-radius:3px; }\n.kg-w-gear { background:rgba(20,15,20,0.8); border-radius:20px; padding:16px; border:1px solid rgba(255,255,255,0.05); display:grid; grid-template-columns:1fr 1fr; gap:8px; }\n.kg-g-title { grid-column:1/-1; font-size:11px; font-weight:800; color:#d4af37; text-transform:uppercase; border-bottom:1px solid rgba(255,255,255,0.05); padding-bottom:6px; margin-bottom:4px; text-align:center; }\n.kg-g-item { background:rgba(20,15,15,0.9); padding:10px; border-radius:6px; border-left:2px solid #3b82f6; display:flex; flex-direction:column; min-width:0; transition:all 0.2s ease; }\n.kg-g-item:hover { transform:translateY(-2px); box-shadow:0 4px 10px rgba(0,0,0,0.4); border-color:#8b5cf6; }\n.kg-g-label { font-size:9px; font-weight:800; color:#93c5fd; text-transform:uppercase; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }\n.kg-g-val { font-size:11px; margin-top:4px; line-height:1.3; overflow-wrap:break-word; word-wrap:break-word; hyphens:auto; }\n\n/* СТИЛИ ПРИЛОЖЕНИЯ DM */\n.kg-chat-head { padding: 10px 16px 12px; border-bottom: 1px solid #1f1f22; display: flex; align-items: center; flex-shrink: 0; background: #070709; position: sticky; top: 0; z-index: 5; }\n.kg-back-label { cursor: pointer; display: flex; align-items: center; }\n.kg-back-btn { width: 24px; height: 24px; stroke: #fff; fill: none; stroke-width: 2.5; margin-right: 14px; transition: transform 0.2s; }\n.kg-back-label:hover .kg-back-btn { transform: translateX(-4px); stroke: #d4af37; filter: drop-shadow(0 0 5px #d4af37); }\n.kg-dm-pfp { width: 34px; height: 34px; border-radius: 50%; background: #1a1a1e; display: flex; justify-content: center; align-items: center; font-weight: 800; font-size: 12px; color: #d4af37; border: 1px solid #333; flex-shrink: 0; }\n.kg-chat-info { display: flex; flex-direction: column; margin-left: 12px; flex: 1; }\n.kg-c-name { font-size: 14px; font-weight: 800; }\n.kg-c-status { font-size: 11px; color: #a1a1aa; margin-top: 2px; }\n.kg-chat-icons { display: flex; gap: 16px; margin-left: auto; }\n.kg-chat-icons svg { width: 22px; height: 22px; stroke: #fff; fill: none; stroke-width: 2; transition: all 0.2s; cursor: pointer; }\n.kg-chat-icons svg:hover { stroke: #d4af37; transform: scale(1.1); filter: drop-shadow(0 0 5px rgba(212,175,55,0.5)); }\n.kg-app-scroll { flex: 1; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 14px; scrollbar-width: none; }\n.kg-app-scroll::-webkit-scrollbar { display: none; }\n.kg-msg-row { display: flex; width: 100%; }\n.kg-msg-row:has(.kg-bubble:empty) { display: none; }\n.kg-msg-Them { justify-content: flex-start; }\n.kg-msg-Me { justify-content: flex-end; }\n.kg-bubble { max-width: 75%; padding: 10px 14px; border-radius: 20px; font-size: 13.5px; line-height: 1.4; word-wrap: break-word; animation: slideUpApp 0.3s ease-out forwards; }\n.kg-msg-Them .kg-bubble { background: #1f1f22; color: #e5e5e5; border-bottom-left-radius: 4px; border: 1px solid #333; }\n.kg-msg-Me .kg-bubble { background: linear-gradient(135deg, #d4af37, #a18a36); color: #000; border-bottom-right-radius: 4px; font-weight: 600; box-shadow: 0 2px 8px rgba(212,175,55,0.2); }\n.kg-bubble img { width: 100%; max-width: 220px; border-radius: 12px; margin: 2px 0; object-fit: contain; }\n.kg-msg-Me .kg-bubble img { border: 2px solid rgba(0,0,0,0.2); }\n.kg-chat-input-bar { padding: 12px 16px 24px; background: rgba(7,7,9,0.98); border-top: 1px solid #1f1f22; display: flex; align-items: center; gap: 12px; flex-shrink: 0; }\n.kg-cam-btn { width: 38px; height: 38px; background: linear-gradient(135deg, #d4af37, #b48512); border-radius: 50%; display: flex; justify-content: center; align-items: center; flex-shrink: 0; cursor: pointer; transition: transform 0.2s; }\n.kg-cam-btn:hover { transform: scale(1.05); }\n.kg-cam-btn svg { width: 20px; height: 20px; fill: #000; }\n.kg-input-box { flex: 1; background: #1f1f22; border-radius: 22px; padding: 10px 14px; display: flex; align-items: center; justify-content: space-between; border: 1px solid #333; }\n.kg-placeholder { color: #888; font-size: 13px; font-weight: 500; }\n.kg-input-icons { display: flex; gap: 12px; }\n.kg-input-icons svg { width: 22px; height: 22px; stroke: #aaa; fill: none; stroke-width: 2; cursor: pointer; transition: stroke 0.2s; }\n.kg-input-icons svg:hover { stroke: #d4af37; }\n</style>\n\n<div class=\"kg-smart\">\n  <input type=\"checkbox\" id=\"kg-lock-$1-$42\" class=\"kg-chk kg-chk-lock\" autocomplete=\"off\">\n  <input type=\"checkbox\" id=\"kg-shade-$1-$42\" class=\"kg-chk kg-chk-shade\" autocomplete=\"off\">\n\n  <div class=\"kg-screen\">\n    <div class=\"kg-topbar\">\n      <span>$1</span>\n      <div class=\"kg-batt-wrap\">\n        <span>$42%</span>\n        <div class=\"kg-batt-icon\"><div class=\"kg-batt-fill\" style=\"width:$42%;\"></div></div>\n      </div>\n    </div>\n    <div class=\"kg-notch\"><div class=\"kg-lens\"></div><div class=\"kg-sensor\"></div></div>\n\n    \n    <div class=\"kg-layer-app\" style=\"display:flex; flex-direction:column;\">\n      <label for=\"kg-shade-$1-$42\" class=\"kg-shade-handle\" title=\"Стянуть шторку\"></label>\n      \n      <div class=\"kg-chat-head\">\n        <label for=\"kg-lock-$1-$42\" class=\"kg-back-label\" title=\"Закрыть\">\n           <svg class=\"kg-back-btn\" viewBox=\"0 0 24 24\"><path d=\"M15 18l-6-6 6-6\"/></svg>\n        </label>\n        <div class=\"kg-dm-pfp\">$31</div><div class=\"kg-chat-info\"><span class=\"kg-c-name\">$30</span><span class=\"kg-c-status\">$33</span></div>\n        <div class=\"kg-chat-icons\"><svg viewBox=\"0 0 24 24\"><path d=\"M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z\"/></svg><svg viewBox=