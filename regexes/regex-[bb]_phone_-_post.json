x; background:rgba(0,0,0,0.5); border-radius:3px; }\n.kg-n-fill { height:100%; border-radius:3px; }\n.kg-w-gear { background:rgba(20,15,20,0.8); border-radius:20px; padding:16px; border:1px solid rgba(255,255,255,0.05); display:grid; grid-template-columns:1fr 1fr; gap:8px; }\n.kg-g-title { grid-column:1/-1; font-size:11px; font-weight:800; color:#d4af37; text-transform:uppercase; border-bottom:1px solid rgba(255,255,255,0.05); padding-bottom:6px; margin-bottom:4px; text-align:center; }\n.kg-g-item { background:rgba(20,15,15,0.9); padding:10px; border-radius:6px; border-left:2px solid #3b82f6; display:flex; flex-direction:column; min-width:0; transition:all 0.2s ease; }\n.kg-g-item:hover { transform:translateY(-2px); box-shadow:0 4px 10px rgba(0,0,0,0.4); border-color:#8b5cf6; }\n.kg-g-label { font-size:9px; font-weight:800; color:#93c5fd; text-transform:uppercase; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }\n.kg-g-val { font-size:11px; margin-top:4px; line-height:1.3; overflow-wrap:break-word; word-wrap:break-word; hyphens:auto; }\n.kg-home-bar { display:flex; justify-content:center; align-items:center; padding:15px; cursor:pointer; margin-top:auto; position:relative; z-index:20; opacity:0.5; transition:all 0.3s; width:100%; }\n.kg-home-bar::after { content:''; width:14px; height:14px; border-right:3px solid #d4af37; border-bottom:3px solid #d4af37; transform:rotate(45deg); border-radius:2px; }\n.kg-home-bar:hover { opacity:1; filter:drop-shadow(0 0 8px #d4af37); transform:translateY(3px); }\n\n/* СТИЛИ ПРИЛОЖЕНИЯ ПОСТА */\n.kg-app-head { padding: 8px 16px 12px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #1f1f22; flex-shrink: 0; }\n.kg-logo-wrap { display: flex; align-items: center; gap: 8px; }\n.kg-logo { font-family: 'Georgia', serif; font-size: 20px; font-style: italic; font-weight: 800; background: linear-gradient(90deg, #fff 0%, #d4af37 50%, #fff 100%); background-size: 200% auto; color: transparent; -webkit-background-clip: text; letter-spacing: 0.5px; animation: textShine 4s linear infinite; }\n@keyframes textShine { to { background-position: 200% center; } }\n.kg-logo-heart { width: 18px; height: 18px; fill: #ef4444; filter: drop-shadow(0 0 5px rgba(239,68,68,0.6)); animation: heartBeat 2s infinite; }\n@keyframes heartBeat { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.15); } }\n.kg-app-head > svg { width: 24px; height: 24px; stroke: #fff; fill: none; }\n\n.kg-post-head { display: flex; align-items: center; padding: 12px 16px; }\n.kg-pfp { position: relative; width: 36px; height: 36px; display: flex; justify-content: center; align-items: center; flex-shrink: 0; }\n.kg-pfp::before { content: ''; position: absolute; inset: 0; border-radius: 50%; padding: 2px; background: linear-gradient(45deg, #d4af37, #ef4444, #9333ea, #d4af37); background-size: 300% 300%; animation: borderSpin 4s ease infinite; -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0); -webkit-mask-composite: xor; mask-composite: exclude; }\n@keyframes borderSpin { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }\n.kg-pfp-in { width: 28px; height: 28px; border-radius: 50%; background: #1a1a1e; display: flex; justify-content: center; align-items: center; font-weight: 800; font-size: 11px; color: #d4af37; text-transform: uppercase; }\n.kg-user-info { margin-left: 10px; display: flex; flex-direction: column; }\n.kg-uname { font-size: 13.5px; font-weight: 800; color: #fff; }\n.kg-uloc { font-size: 11px; color: #a1a1aa; margin-top: 1px; }\n.kg-dots { margin-left: auto; width: 20px; height: 20px; fill: #aaa; transition: all 0.2s; cursor: pointer; }\n.kg-dots:hover { fill: #d4af37; filter: drop-shadow(0 0 6px rgba(212,175,55,0.6)); transform: scale(1.1); }\n\n.kg-img-wrapper { width: 100%; padding-top: 100%; position: relative; background: #000; border-top: 1px solid #1f1f22; border-bottom: 1