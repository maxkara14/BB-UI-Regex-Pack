t:''; width:40px; height:5px; background:rgba(255,255,255,0.4); border-radius:3px; }\n.kg-shade-content { flex:1; padding:0 15px 15px 15px; display:flex; flex-direction:column; gap:15px; }\n.kg-layer-lock { position:absolute; inset:0; background:linear-gradient(to bottom, rgba(10,10,15,0.3), #070709), url('https://images2.imgbox.com/cd/d4/j6VOin3X_o.png') center/cover; z-index:40; display:flex; flex-direction:column; align-items:center; padding-top:80px; transition:transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease; }\n.kg-chk-lock:checked ~ .kg-screen .kg-layer-lock { transform:translateY(-100%); opacity:0; pointer-events:none; }\n.kg-l-time { font-size:70px; font-weight:200; line-height:1; text-shadow:0 4px 10px rgba(0,0,0,0.8); }\n.kg-l-date { font-size:14px; font-weight:600; color:#d4af37; text-transform:uppercase; margin-top:5px; text-shadow:0 2px 4px rgba(0,0,0,0.8); }\n.kg-l-notif { background:rgba(20,20,25,0.7); border:1px solid rgba(255,255,255,0.1); border-radius:16px; padding:14px 16px; width:85%; margin-top:35px; backdrop-filter:blur(5px); }\n.kg-notif-head { display:flex; align-items:center; gap:8px; margin-bottom:6px; }\n.kg-bell { width:14px; height:14px; color:#fca5a5; transform-origin:top center; animation:ringBell 4s infinite; }\n.kg-unlock-btn { position:absolute; bottom:40px; font-size:11px; font-weight:600; color:rgba(255,255,255,0.6); text-transform:uppercase; letter-spacing:2px; cursor:pointer; animation:kgPulse 2s infinite; padding:10px; text-shadow:0 1px 2px #000; }\n.kg-w-mood { background:rgba(20,15,20,0.8); border-radius:20px; padding:16px; border:1px solid rgba(255,255,255,0.05); border-left:4px solid var(--c, #d4af37); display:flex; flex-direction:column; gap:14px; }\n.kg-m-head { display:flex; align-items:flex-start; gap:14px; }\n.kg-gem { width:34px; height:34px; border-radius:50%; border:3px solid var(--c, #d4af37); background:#111; flex-shrink:0; position:relative; animation:gemPulse 4s infinite ease-in-out; }\n.kg-gem::