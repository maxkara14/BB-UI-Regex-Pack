    "findRegex": "::RADIO_START::[\\s\\S]*?Comment:\\s*([\\s\\S]*?)\\s*::RADIO_END::",
    "replaceString": "<style>\n@keyframes eqBounce { 0% { height: 4px; } 100% { height: 24px; } }\n@keyframes slideMarquee { 0% { transform: translateX(100%); } 100% { transform: translateX(-100%); } }\n@keyframes pulseLive { 0%, 100% { box-shadow: 0 0 5px rgba(220, 38, 38, 0.4); } 50% { box-shadow: 0 0 15px rgba(220, 38, 38, 0.9); } }\n@keyframes blinkDot { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }\n@keyframes fadeInSlide { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }\n\n.lycoris-radio-wrapper {\n  margin: 20px 0; font-family: 'Georgia', -apple-system, sans-serif;\n  width: 100%; box-sizing: border-box;\n}\n\n.lycoris-radio-wrapper > summary {\n  list-style: none; outline: none; cursor: pointer;\n  background: linear-gradient(135deg, #1e1313, #120a0a);\n  border: 1px solid #3f2c2c; border-left: 4px solid #b91c1c;\n  border-radius: 6px; padding: 12px 18px;\n  display: flex; align-items: center; justify-content: space-between;\n  color: #d4af37; font-weight: 800; text-transform: uppercase; letter-spacing: 2px;\n  box-shadow: 0 4px 15px rgba(0,0,0,0.6); transition: all 0.3s ease;\n}\n.lycoris-radio-wrapper > summary::-webkit-details-marker { display: none; }\n.lycoris-radio-wrapper > summary:hover { border-color: #d4af37; background: #2a1a1a; box-shadow: 0 4px 20px rgba(185, 28, 28, 0.3); }\n\n.l-live-badge {\n  display: flex; align-items: center; gap: 8px; \n  background: rgba(185, 28, 28, 0.2); border: 1px solid #b91c1c;\n  padding: 4px 10px; border-radius: 4px; color: #fca5a5; \n  font-size: 0.75em; font-family: -apple-system, sans-serif; letter-spacing: 1px;\n  animation: pulseLive 2s infinite ease-in-out;\n}\n.l-live-dot {\n  width: 8px; height: 8px; background: #ef4444; \n  border-radius: 50%; box-shadow: 0 0 5px #ef4444;\n  animation: blinkDot 1s infinite;\n}\n\n.l-podcast-body {\n  background: #0f0a0a; border: 1px solid #3f2c2c; border-top: 2px solid #b91c1c;\n  border-radius: 8px; margin-top: 12px; padding: 18px; \n  display: flex; flex-direction: column; gap: 16px;\n  box-shadow: inset 0 0 30px rgba(0,0,0,0.9), 0 10px 30px rgba(0,0,0,0.6);\n  position: relative; overflow: hidden;\n  animation: fadeInSlide 0.4s ease forwards;\n}\n.l-podcast-body::before {\n  content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0;\n  background-image: radial-gradient(rgba(212,175,55,0.03) 1px, transparent 1px);\n  background-size: 4px 4px; pointer-events: none;\n}\n\n.l-top-section { display: flex; gap: 16px; align-items: stretch; position: relative; z-index: 1; }\n\n.l-avatar {\n  width: 90px; height: 90px; flex-shrink: 0; \n  background: #0a0a0c;\n  border-radius: 6px; border: 1px solid #d4af37; position: relative;\n  box-shadow: 0 4px 15px rgba(0,0,0,0.8), inset 0 0 15px rgba(212,175,55,0.1); \n  overflow: hidden;\n}\n.l-avatar-image {\n  width: 100%; height: 100%;\n  background-image: url('https://thumbs2.imgbox.com/01/b7/7F9s33DP_t.png'); \n  background-size: cover; background-position: center; background-repeat: no-repeat;\n  filter: contrast(1.1) brightness(0.9); \n}\n.l-avatar::after {\n  content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0;\n  background: linear-gradient(to bottom, transparent 60%, rgba(10,5,5,0.8));\n  pointer-events: none;\n}\n\n.l-speech-bubble {\n  background: rgba(30, 20, 20, 0.8); border: 1px solid #3f2c2c; border-radius: 8px 8px 8px 2px;\n  padding: 14px 18px; color: #e5e7eb; font-size: 0.95em; line-height: 1.5; font-style: italic;\n  flex-grow: 1; position: relative; box-shadow: inset 0 0 15px rgba(0,0,0,0.5);\n  display: flex; flex-direction: column; justify-content: center;\n}\n.l-speech-bubble::before {\n  content: ''; position: absolute; left: -10px; bottom: -1px;\n  border-width: 0 10px 14px 0; border-style: solid; border-color: transparent #3f2c2c transparent transparent;\n}\n.l-speech-bubble::after {\n  content: ''; position: absolute; left: -8px; bottom: 0;\n  border-width: 0 9px 12px 0; border-style: solid; border-color: transparent rgba(30, 20, 20, 0.9) transparent transparent;\n}\n\n.l-player {\n  background: rgba(20, 10, 10, 0.9); border: 1px solid #3f2c2c; border-radius: 6px;\n  padding: 12px 16px; display: flex; align-items: center; justify-content: space-between; gap: 14px;\n  position: relative; z-index: 1; border-left: 3px solid #d4af37;\n}\n.l-track-info { flex-grow: 1; overflow: hidden; display: flex; flex-direction: column; gap: 4px; }\n.l-now-playing { font-size: 0.65em; color: #9ca3af; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; font-family: -apple-system, sans-serif; }\n\n.l-marquee {\n  width: 100%; overflow: hidden; position: relative; padding: 2px 0;\n}\n.l-marquee span {\n  display: inline-block; white-space: nowrap; animation: slideMarquee 15s linear infinite;\n  color: #fef08a; font-weight: bold; font-size: 0.85em; letter-spacing: 1px;\n  font-family: -apple-system, sans-serif;\n}\n\n.l-eq { display: flex; align-items: flex-end; gap: 3px; height: 24px; padding-bottom: 2px; margin-right: 5px; }\n.l-eq span { display: block; width: 4px; background: linear-gradient(to top, #b91c1c, #d4af37); border-radius: 1px; animation: eqBounce 0.5s alternate infinite ease-in-out; }\n.l-eq span:nth-child(1) { animation-delay: 0.1s; }\n.l-eq span:nth-child(2) { animation-delay: 0.3s; }\n.l-eq span:nth-child(3) { animation-delay: 0.0s; }\n.l-eq span:nth-child(4) { animation-delay: 0.4s; }\n.l-eq span:nth-child(5) { animation-delay: 0.2s; }\n\n/* ЭЛИТНЫЙ ТЮНИНГ АУДИОПЛЕЕРА - СВЕТЛАЯ ВЕРСИЯ */\n.l-audio-container {\n  margin-top: 6px; width: 100%; max-width: 300px;\n}\naudio.l-audio-player {\n  width: 100%; height: 32px; display: block; outline: none;\n  filter: invert(0.8) hue-rotate(180deg) saturate(2);\n}\n/* Делаем фон плеера чуть светлее */\naudio.l-audio-player::-webkit-media-controls-enclosure {\n  background: linear-gradient(135deg, rgba(55, 40, 40, 0.9), rgba(35, 25, 25, 0.9));\n  border: 1px solid rgba(212,175,55,0.4); border-radius: 6px;\n}\n/* Делаем кнопки ярче */\naudio.l-audio-player::-webkit-media-controls-play-button,\naudio.l-audio-player::-webkit-media-controls-mute-button {\n  filter: sepia(1) hue-rotate(330deg) saturate(3) brightness(1.3); cursor: pointer;\n}\naudio.l-audio-player::-webkit-media-controls-timeline {\n  display: none !important;\n}\naudio.l-audio-player::-webkit-media-controls-current-time-display,\naudio.l-audio-player::-webkit-media-controls-time-remaining-display {\n  color: #d4af37; text-shadow: none; font-family: -apple-system, sans-serif; font-size: 0.9em;\n}\n</style>\n\n<details class=\"lycoris-radio-wrapper\">\n  <summary>\n    <span>🎙️ LYCORIS FM</span>\n    <div class=\"l-live-badge\"><div class=\"l-live-dot\"></div> LIVE</div>\n  </summary>\n  \n  <div class=\"l-podcast-body\">\n    <div class=\"l-top-section\">\n      <div class=\"l-avatar\">\n        <div class=\"l-avatar-image\"></div>\n      </div>\n      <div class=\"l-speech-bubble\">\n        $1\n      </div>\n    </div>\n    \n    <div class=\"l-player\">\n      <div class=\"l-track-info\">\n        <span class=\"l-now-playing\">LIVE BROADCAST</span>\n        <div class=\"l-marquee\">\n          <span>♪ 104.5 LYCORIS FM • 24/7 ROCK MIX ♪ 104.5 LYCORIS FM • 24/7 ROCK MIX ♪</span>\n        </div>\n        <div class=\"l-audio-container\">\n          <audio class=\"l-audio-player\" controls preload=\"none\" src=\"https://stream.radioparadise.com/rock-128\" </audio>\n        </div>\n      </div>\n      <div class=\"l-eq\">\n        <span></span><span></span><span></span><span></span><span></span>\n      </div>\n    </div>\n  </div>\n</details>",
