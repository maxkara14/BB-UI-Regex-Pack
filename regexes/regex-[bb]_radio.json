    "replaceString": "<style>\n@keyframes kairEq { 0% { height: 4px; } 100% { height: 24px; } }\n@keyframes kairMarquee { 0% { transform: translateX(100%); } 100% { transform: translateX(-100%); } }\n@keyframes kairLive { 0%, 100% { box-shadow: 0 0 5px rgba(220,38,38,0.4); } 50% { box-shadow: 0 0 15px rgba(220,38,38,0.9); } }\n@keyframes kairDot { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }\n@keyframes fireFlicker { 0%, 100% { transform: scale(1) rotate(-5deg); filter: drop-shadow(0 0 4px rgba(250,204,21,0.6)); } 50% { transform: scale(1.15) rotate(5deg); filter: drop-shadow(0 0 10px rgba(239,68,68,0.9)); } }\n\n.kair-wrap { margin: 24px 0; font-family: 'Courier New', Courier, monospace, -apple-system; width: 100%; box-sizing: border-box; background: #0a0a0a; border: 1px solid #262626; border-left: 4px solid #facc15; border-radius: 6px; box-shadow: 0 6px 20px rgba(0,0,0,0.8); transition: box-shadow 0.3s ease; overflow: hidden; }\n.kair-wrap:hover { box-shadow: 0 8px 25px rgba(250,204,21,0.15); }\n\n.kair-label { display: block; cursor: pointer; margin: 0; padding: 0; }\n.kair-summary { background: linear-gradient(180deg, #171717, #0a0a0a); padding: 14px 20px; display: flex; align-items: center; justify-content: space-between; color: #facc15; font-weight: 900; text-transform: uppercase; letter-spacing: 2px; position: relative; z-index: 2; transition: all 0.3s ease; border-bottom: 1px solid transparent; user-select: none; font-family: 'Impact', 'Arial Black', sans-serif; }\n.kair-label:hover .kair-summary { background: linear-gradient(180deg, #262626, #171717); }\n\n.kair-wrap:has(.kair-toggle:checked) .kair-summary { border-bottom: 1px solid #404040; background: #0a0a0a; box-shadow: 0 4px 15px rgba(0,0,0,0.9); }\n.kair-wrap:has(.kair-toggle:checked) .kair-grid-wrapper { grid-template-rows: 1fr; opacity: 1; transform: translateY(0); }\n\n.kair-grid-wrapper { display: grid; grid-template-rows: 0fr; opacity: 0; transform: translateY(-15px); transition: grid-template-rows 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.3s ease, transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1); position: relative; z-index: 1; }\n.kair-grid-inner { overflow: hidden; }\n\n.kair-fire { display: inline-block; animation: fireFlicker 1.5s ease-in-out infinite; transform-origin: center; margin-right: 6px; }\n.kair-live-badge { display: flex; align-items: center; gap: 8px; background: rgba(220,38,38,0.15); border: 1px solid rgba(220,38,38,0.5); padding: 4px 12px; border-radius: 4px; color: #fca5a5; font-size: 0.8em; font-family: -apple-system, sans-serif; letter-spacing: 1px; font-weight: bold; animation: kairLive 2s infinite ease-in-out; }\n.kair-live-dot { width: 8px; height: 8px; background: #ef4444; border-radius: 50%; box-shadow: 0 0 8px #ef4444; animation: kairDot 1s infinite; }\n\n.kair-body { background: linear-gradient(180deg, #121212, #050505); padding: 24px 20px 20px 20px; display: flex; flex-direction: column; gap: 20px; position: relative; z-index: 1; box-shadow: inset 0 10px 20px rgba(0,0,0,0.8); }\n.kair-body::before { content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-image: radial-gradient(rgba(250,204,21,0.05) 1px, transparent 1px); background-size: 6px 6px; pointer-events: none; }\n\n.kair-top { display: flex; gap: 16px; align-items: stretch; position: relative; z-index: 1; }\n.kair-avatar { width: 90px; height: 90px; flex-shrink: 0; background: #000; border-radius: 6px; border: 1px solid #404040; position: relative; box-shadow: 0 4px 15px rgba(0,0,0,0.9); overflow: hidden; }\n.kair-avatar-image { width: 100%; height: 100%; background-image: url('https://thumbs2.imgbox.com/01/b7/7F9s33DP_t.png'); background-size: cover; background-position: center; background-repeat: no-repeat; filter: contrast(1.15) brightness(0.9) grayscale(0.2); }\n\n.kair-bubble { background: #171717; border: 1px solid #404040; border-radius: 8px; padding: 16px 20px; color: #e5e5e5; font-size: 0.95em; line-height: 1.6; font-style: italic; font-family: 'Georgia', serif; flex-grow: 1; position: relative; box-shadow: inset 0 0 15px rgba(0,0,0,0.8), 0 4px 10px rgba(0,0,0,0.5); white-space: pre-wrap; word-wrap: break-word; border-bottom: 2px solid #facc15; }\n.kair-bubble p, .kair-bubble div, .kair-bubble span, .kair-bubble blockquote { display: inline !important; margin: 0 !important; padding: 0 !important; }\n.kair-bubble > br { display: none !important; }\n\n.kair-player { background: #0a0a0a; border: 1px solid #262626; border-radius: 6px; padding: 14px 20px; display: flex; align-items: center; justify-content: space-between; gap: 20px; position: relative; z-index: 1; border-left: 3px solid #facc15; box-shadow: inset 0 0 20px rgba(0,0,0,0.9); }\n.kair-track { flex-grow: 1; overflow: hidden; display: flex; flex-direction: column; gap: 8px; }\n.kair-row { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 1px solid #262626; padding-bottom: 6px; margin-bottom: 2px; }\n.kair-now { font-size: 0.65em; color: #a3a3a3; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; font-family: -apple-system, sans-serif; }\n.kair-freq { font-size: 0.6em; color: #facc15; font-family: monospace; letter-spacing: 1px; font-weight: bold; }\n.kair-marquee { width: 100%; overflow: hidden; position: relative; padding: 2px 0; -webkit-mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent); mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent); }\n.kair-marquee span { display: inline-block; white-space: nowrap; animation: kairMarquee 15s linear infinite; color: #facc15; font-weight: bold; font-size: 0.85em; letter-spacing: 1.5px; font-family: -apple-system, sans-serif; text-shadow: 0 0 5px rgba(250,204,21,0.4); }\n\n.kair-eq-box { background: #000; border: 1px solid #262626; border-radius: 4px; padding: 8px 10px; box-shadow: inset 0 0 10px rgba(0,0,0,0.9); height: 36px; display: flex; align-items: center; justify-content: center; }\n.kair-eq { display: flex; align-items: flex-end; gap: 4px; height: 28px; }\n.kair-eq span { display: block; width: 4px; background: linear-gradient(to top, #facc15, #dc2626); border-radius: 1px; animation: kairEq 0.5s alternate infinite ease-in-out; }\n.kair-eq span:nth-child(1) { animation-delay: 0.1s; } .kair-eq span:nth-child(2) { animation-delay: 0.3s; } .kair-eq span:nth-child(3) { animation-delay: 0.0s; } .kair-eq span:nth-child(4) { animation-delay: 0.4s; } .kair-eq span:nth-child(5) { animation-delay: 0.2s; }\n\n.kair-audio-container { margin-top: 4px; width: 100%; max-width: 320px; }\naudio.kair-audio { width: 100%; height: 32px; display: block; outline: none !important; box-shadow: none !important; color-scheme: dark; }\naudio.kair-audio::-webkit-media-controls-enclosure, audio.kair-audio::-webkit-media-controls-panel { background: #171717 !important; border: 1px solid #404040; border-radius: 4px; }\naudio.kair-audio::-webkit-media-controls-play-button, audio.kair-audio::-webkit-media-controls-mute-button, audio.kair-audio::-webkit-media-controls-volume-slider, audio.kair-audio::-webkit-media-controls-current-time-display, audio.kair-audio::-webkit-media-controls-time-remaining-display { cursor: pointer; filter: sepia(1) saturate(10) hue-rotate(5deg) brightness(1.2) !important; }\naudio.kair-audio::-webkit-media-controls-timeline { display: none !important; }\n</style>\n<div class=\"kair-wrap\"><label class=\"kair-label\"><input type=\"checkbox\" class=\"kair-toggle\" style=\"display:none;\"><div class=\"kair-summary\"><span><span class=\"kair-fire\">🔥</span> 104.5 LYCORIS FM</span><div class=\"kair-live-badge\"><div class=\"kair-live-dot\"></div> LIVE</div></div></label><div class=\"kair-grid-wrapper\"><div class=\"kair-grid-inner\"><div class=\"kair-body\"><div class=\"kair-top\"><div class=\"kair-avatar\"><div class=\"kair-avatar-image\"></div></div><div class=\"kair-bubble\">$1</div></div><div class=\"kair-player\"><div class=\"kair-track\"><div class