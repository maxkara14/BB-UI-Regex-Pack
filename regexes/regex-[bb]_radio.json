{
    "id": "5cd458b0-0685-4a26-88de-526920e935dd",
    "scriptName": "[BB] radio",
    "findRegex": "::RADIO_START::[\\s\\S]*?Comment:\\s*([\\s\\S]*?)\\s*Song:\\s*([\\s\\S]*?)\\s*::RADIO_END::",
    "replaceString": "<style>\n@keyframes eqBounce { 0% { height: 4px; } 100% { height: 24px; } }\n@keyframes slideMarquee { 0% { transform: translateX(100%); } 100% { transform: translateX(-100%); } }\n@keyframes pulseLive { 0%, 100% { box-shadow: 0 0 5px rgba(220, 38, 38, 0.4); } 50% { box-shadow: 0 0 15px rgba(220, 38, 38, 0.9); } }\n@keyframes blinkDot { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }\n@keyframes fadeInSlide { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }\n\n.lycoris-radio-wrapper {\n  margin: 20px 0; font-family: 'Georgia', -apple-system, sans-serif;\n  width: 100%; box-sizing: border-box;\n}\n\n/* Стилизация кнопки раскрытия */\n.lycoris-radio-wrapper > summary {\n  list-style: none; outline: none; cursor: pointer;\n  background: linear-gradient(135deg, #1e1313, #120a0a);\n  border: 1px solid #3f2c2c; border-left: 4px solid #b91c1c;\n  border-radius: 6px; padding: 12px 18px;\n  display: flex; align-items: center; justify-content: space-between;\n  color: #d4af37; font-weight: 800; text-transform: uppercase; letter-spacing: 2px;\n  box-shadow: 0 4px 15px rgba(0,0,0,0.6); transition: all 0.3s ease;\n}\n.lycoris-radio-wrapper > summary::-webkit-details-marker { display: none; }\n.lycoris-radio-wrapper > summary:hover { border-color: #d4af37; background: #2a1a1a; box-shadow: 0 4px 20px rgba(185, 28, 28, 0.3); }\n\n/* Анимированная кнопка LIVE */\n.l-live-badge {\n  display: flex; align-items: center; gap: 8px; \n  background: rgba(185, 28, 28, 0.2); border: 1px solid #b91c1c;\n  padding: 4px 10px; border-radius: 4px; color: #fca5a5; \n  font-size: 0.75em; font-family: -apple-system, sans-serif; letter-spacing: 1px;\n  animation: pulseLive 2s infinite ease-in-out;\n}\n.l-live-dot {\n  width: 8px; height: 8px; background: #ef4444; \n  border-radius: 50%; box-shadow: 0 0 5px #ef4444;\n  animation: blinkDot 1s infinite;\n}\n\n/* Основной контейнер подкаста */\n.l-podcast-body {\n  background: #0f0a0a; border: 1px solid #3f2c2c; border-top: 2px solid #b91c1c;\n  border-radius: 8px; margin-top: 12px; padding: 18px; \n  display: flex; flex-direction: column; gap: 18px;\n  box-shadow: inset 0 0 30px rgba(0,0,0,0.9), 0 10px 30px rgba(0,0,0,0.6);\n  position: relative; overflow: hidden;\n  animation: fadeInSlide 0.4s ease forwards;\n}\n.l-podcast-body::before {\n  content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0;\n  background-image: radial-gradient(rgba(212,175,55,0.03) 1px, transparent 1px);\n  background-size: 4px 4px; pointer-events: none;\n}\n\n/* Верхняя часть: Аватар и Текст */\n.l-top-section { display: flex; gap: 16px; align-items: stretch; position: relative; z-index: 1; }\n\n/* ОБНОВЛЕННЫЙ БЛОК АВАТАРА (Под картинку) */\n.l-avatar {\n  width: 90px; height: 90px; flex-shrink: 0; \n  background: #0a0a0c;\n  border-radius: 6px; border: 1px solid #d4af37; position: relative;\n  box-shadow: 0 4px 15px rgba(0,0,0,0.8), inset 0 0 15px rgba(212,175,55,0.1); \n  overflow: hidden;\n}\n/* Сюда вставлять ссылку на картинку! */\n.l-avatar-image {\n  width: 100%; height: 100%;\n  background-image: url('https://thumbs2.imgbox.com/01/b7/7F9s33DP_t.png'); /* ЗАМЕНИТЬ ЭТУ ССЫЛКУ */\n  background-size: cover;\n  background-position: center;\n  background-repeat: no-repeat;\n  filter: contrast(1.1) brightness(0.9); /* Лёгкая цветокоррекция под стиль */\n}\n/* Небольшой градиент поверх картинки, чтобы она лучше вписывалась в темную тему */\n.l-avatar::after {\n  content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0;\n  background: linear-gradient(to bottom, transparent 60%, rgba(10,5,5,0.8));\n  pointer-events: none;\n}\n\n.l-speech-bubble {\n  background: rgba(30, 20, 20, 0.8); border: 1px solid #3f2c2c; border-radius: 8px 8px 8px 2px;\n  padding: 14px 18px; color: #e5e7eb; font-size: 0.95em; line-height: 1.5; font-style: italic;\n  flex-grow: 1; position: relative; box-shadow: inset 0 0 15px rgba(0,0,0,0.5);\n  display: flex; flex-direction: column; justify-content: center;\n}\n.l-speech-bubble::before {\n  content: ''; position: absolute; left: -10px; bottom: -1px;\n  border-width: 0 10px 14px 0; border-style: solid; border-color: transparent #3f2c2c transparent transparent;\n}\n.l-speech-bubble::after {\n  content: ''; position: absolute; left: -8px; bottom: 0;\n  border-width: 0 9px 12px 0; border-style: solid; border-color: transparent rgba(30, 20, 20, 0.9) transparent transparent;\n}\n\n/* Кастомный Плеер */\n.l-player {\n  background: rgba(20, 10, 10, 0.9); border: 1px solid #3f2c2c; border-radius: 4px;\n  padding: 12px 16px; display: flex; align-items: center; justify-content: space-between; gap: 14px;\n  position: relative; z-index: 1; border-left: 3px solid #d4af37;\n}\n.l-track-info { flex-grow: 1; overflow: hidden; display: flex; flex-direction: column; gap: 6px; }\n.l-now-playing { font-size: 0.65em; color: #9ca3af; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; font-family: -apple-system, sans-serif; }\n\n.l-marquee {\n  width: 100%; overflow: hidden; position: relative; \n  padding: 2px 0;\n}\n.l-marquee a {\n  display: inline-block; white-space: nowrap; animation: slideMarquee 15s linear infinite;\n  color: #fef08a; font-weight: bold; text-decoration: none; font-size: 0.95em; letter-spacing: 1px;\n  font-family: -apple-system, sans-serif;\n}\n.l-marquee a:hover { color: #fff; text-shadow: 0 0 8px #d4af37; }\n\n.l-eq { display: flex; align-items: flex-end; gap: 3px; height: 24px; padding-bottom: 2px; }\n.l-eq span { display: block; width: 4px; background: linear-gradient(to top, #b91c1c, #d4af37); border-radius: 1px; animation: eqBounce 0.5s alternate infinite ease-in-out; }\n.l-eq span:nth-child(1) { animation-delay: 0.1s; }\n.l-eq span:nth-child(2) { animation-delay: 0.3s; }\n.l-eq span:nth-child(3) { animation-delay: 0.0s; }\n.l-eq span:nth-child(4) { animation-delay: 0.4s; }\n.l-eq span:nth-child(5) { animation-delay: 0.2s; }\n\n.l-play-btn {\n  background: linear-gradient(135deg, #d4af37, #b48512); color: #000; \n  width: 36px; height: 36px; border-radius: 50%;\n  display: flex; justify-content: center; align-items: center; text-decoration: none;\n  transition: all 0.3s ease; flex-shrink: 0; box-shadow: 0 0 10px rgba(212,175,55,0.4);\n  border: 2px solid #fff;\n}\n.l-play-btn:hover { transform: scale(1.1); background: #fff; box-shadow: 0 0 20px rgba(212,175,55,0.8); border-color: #d4af37; color: #b91c1c; }\n.l-play-btn svg { width: 14px; height: 14px; fill: currentColor; margin-left: 2px; }\n</style>\n\n<details class=\"lycoris-radio-wrapper\">\n  <summary>\n    <span>🎙️ LYCORIS FM</span>\n    <div class=\"l-live-badge\"><div class=\"l-live-dot\"></div> LIVE</div>\n  </summary>\n  \n  <div class=\"l-podcast-body\">\n    <div class=\"l-top-section\">\n      \n      <div class=\"l-avatar\">\n        <div class=\"l-avatar-image\"></div>\n      </div>\n      \n      <div class=\"l-speech-bubble\">\n        $1\n      </div>\n    </div>\n    \n    <div class=\"l-player\">\n      <div class=\"l-track-info\">\n        <span class=\"l-now-playing\">Now Playing</span>\n        <div class=\"l-marquee\">\n          <a href=\"https://www.youtube.com/results?search_query=$2\" target=\"_blank\">\n            ♪ $2 ♪ $2 ♪ $2 ♪\n          </a>\n        </div>\n      </div>\n      <div class=\"l-eq\">\n        <span></span><span></span><span></span><span></span><span></span>\n      </div>\n      <a href=\"https://www.youtube.com/results?search_query=$2\" target=\"_blank\" class=\"l-play-btn\" title=\"Find track on YouTube\">\n        <svg viewBox=\"0 0 24 24\"><path d=\"M8 5v14l11-7z\"/></svg>\n      </a>\n    </div>\n  </div>\n</details>",
