track\"><div class=\"need-fill\" style=\"width:$18%;\"></div></div></div>\n        <div class=\"need-row\"><span class=\"need-label\">HUNGER</span><div class=\"need-track\"><div class=\"need-fill\" style=\"width:$19%;\"></div></div></div>\n        <div class=\"need-row\"><span class=\"need-label\">SOCIAL</span><div class=\"need-track\"><div class=\"need-fill\" style=\"width:$20%;\"></div></div></div>\n        <div class=\"need-row\"><span class=\"need-label\">COMFORT</span><div class=\"need-track\"><div class=\"need-fill\" style=\"width:$21%;\"></div></div></div>\n      </div>\n      \n      <div class=\"feed-divider\">SOCIAL MEDIA</div>\n      <div class=\"feed-area\">\n        <div class=\"section-header\">NEWS</div>\n        <div class=\"event-box\"><span class=\"event-meta\">$29 • $30</span>$31</div>\n        <div class=\"event-box\" style=\"border-left-color:#ef4444;\"><span class=\"event-meta\" style=\"color:#ef4444;\">$32 • $33</span>$34</div>\n        <div class=\"section-header\" style=\"margin-top: 10px;\">COMMENTS</div>\n        <div class=\"comm-card\"><div class=\"comm-header\"><span class=\"comm-nick\">$36</span><span class=\"comm-emoji\">$35</span></div><div class=\"comm-text\">$37</div></div>\n        <div class=\"comm-card\"><div class=\"comm-header\"><span class=\"comm-nick\">$39</span><span class=\"comm-emoji\">$38</span></div><div class=\"comm-text\">$40</div></div>\n        <div class=\"comm-card\"><div class=\"comm-header\"><span class=\"comm-nick\">$42</span><span class=\"comm-emoji\">$41</span></div><div class=\"comm-text\">$43</div></div>\n      </div>\n      <div class=\"home-indicator\"></div>\n    </div>\n  </div>\n\n  <details class=\"gear-wrapper\">\n    <summary>\n      <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\"/></svg>\n      EQUIPMENT\n    </summary>\n    <div class=\"gear-conte