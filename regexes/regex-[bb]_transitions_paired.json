{
    "id": "d4e33dc0-1bc3-478d-ba76-ca2a87c6cd5c",
    "scriptName": "[BB] transitions paired",
    "findRegex": "/⟦([A-Za-zА-Яа-яЁё\\s]+?)\\s*:\\s*(.*?)⟧([\\s\\S]*?)⟦\\/\\s*\\1\\s*⟧/g",
    "replaceString": "<style>\n@keyframes floatEmber {\n  0%, 100% { transform: translateY(0) scale(1); opacity: 0.3; }\n  50% { transform: translateY(-10px) scale(1.3); opacity: 1; }\n}\n.k-paired {\n  background: linear-gradient(to bottom, #1e1313, #160f0f);\n  border: 1px solid #3f2c2c; border-radius: 6px; margin: 24px 0;\n  position: relative;\n  box-shadow: 0 6px 16px rgba(0,0,0,0.6), inset 0 0 10px rgba(0,0,0,0.5);\n  overflow: hidden; width: 100%; box-sizing: border-box;\n}\n.k-p-head {\n  background: linear-gradient(90deg, #7f1d1d, #991b1b, #7f1d1d);\n  padding: 8px 16px; border-bottom: 2px solid #d4af37;\n  display: flex; justify-content: space-between; align-items: center;\n  font-family: 'Georgia', serif; font-size: 0.8em; text-transform: uppercase; letter-spacing: 2px;\n  box-shadow: 0 2px 8px rgba(0,0,0,0.6); position: relative; z-index: 2;\n}\n.k-p-type { color: #fef08a; font-weight: bold; text-shadow: 0 1px 3px rgba(0,0,0,0.8); }\n.k-p-theme { color: #fca5a5; opacity: 0.9; letter-spacing: 1px; }\n\n.k-p-body {\n  padding: 18px 24px; \n  color: #e5e7eb; \n  font-size: 1.05em; \n  line-height: 1.65;\n  font-family: 'Georgia', 'Palatino Linotype', 'Book Antiqua', Palatino, serif; \n  position: relative; z-index: 1; text-shadow: 0 1px 2px rgba(0,0,0,0.8);\n  background-image: radial-gradient(rgba(212,175,55,0.05) 1px, transparent 1px);\n  background-size: 4px 4px;\n}\n.k-p-body p { margin-bottom: 10px; text-indent: 1.5em; }\n\n.ember {\n  position: absolute; width: 3px; height: 3px; background: #fef08a; border-radius: 50%;\n  box-shadow: 0 0 8px #ef4444, 0 0 4px #f59e0b; pointer-events: none;\n}\n.em-1 { top: 15%; right: 10%; animation: floatEmber 3s infinite ease-in-out; }\n.em-2 { bottom: 20%; left: 8%; animation: floatEmber 4.5s infinite ease-in-out 1s; }\n.em-3 { top: 60%; right: 30%; animation: floatEmber 3.8s infinite ease-in-out 0.5s; width: 4px; height: 4px; }\n.em-4 { top: 30%; left: 40%; animation: floatEmber 5s infinite ease-in-out 2s; opacity: 0.5; }\n</style>\n<div class=\"k-paired\">\n  <div class=\"k-p-head\">\n    <span class=\"k-p-type\">$1</span>\n    <span class=\"k-p-theme\">$2</span>\n  </div>\n  <div class=\"k-p-body\">\n    <div class=\"ember em-1\"></div><div class=\"ember em-2\"></div>\n    <div class=\"ember em-3\"></div><div class=\"ember em-4\"></div>\n    $3\n  </div>\n</div>",
