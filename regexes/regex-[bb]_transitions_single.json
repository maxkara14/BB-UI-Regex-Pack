    "findRegex": "/※([A-Za-zА-Яа-яЁё\\s]+?)\\s*:\\s*(.*?)※([\\s\\S]*?)※\\/\\s*\\1\\s*※/g",
    "replaceString": "<style>\n@keyframes sceneFadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }\n@keyframes breathGlow { 0%, 100% { opacity: 0.5; box-shadow: 0 0 4px rgba(212,175,55,0.2); } 50% { opacity: 1; box-shadow: 0 0 12px rgba(212,175,55,0.6); } }\n.k-scene-wrap {\n  margin: 28px 0; width: 100%; box-sizing: border-box;\n  animation: sceneFadeIn 0.7s ease-out forwards;\n}\n.k-single {\n  display: flex; align-items: center; justify-content: center; gap: 12px;\n  font-family: 'Georgia', serif; font-size: 0.85em; text-transform: uppercase; letter-spacing: 2px;\n  position: relative; width: 100%; box-sizing: border-box; margin-bottom: 12px;\n}\n.k-line {\n  flex-grow: 1; height: 1px; \n  background: linear-gradient(90deg, transparent, rgba(220, 38, 38, 0.7), transparent);\n  animation: breathGlow 4s infinite ease-in-out;\n}\n.k-emblem {\n  width: 6px; height: 6px; transform: rotate(45deg);\n  border: 1px solid rgba(212,175,55,0.8); background: #120a0a; \n  animation: breathGlow 4s infinite ease-in-out; flex-shrink: 0;\n}\n.k-type { color: #d4af37; font-weight: bold; text-shadow: 0 0 8px rgba(212,175,55,0.4); white-space: nowrap; }\n.k-desc { color: #fca5a5; font-size: 0.85em; opacity: 0.9; letter-spacing: 1px; white-space: nowrap; }\n.k-scene-body {\n  padding: 12px 20px; color: #e5e7eb; font-size: 1.05em; line-height: 1.6;\n  font-family: 'Georgia', serif; text-shadow: 0 1px 2px rgba(0,0,0,0.8);\n  border-left: 1px solid rgba(220, 38, 38, 0.4);\n  background: linear-gradient(90deg, rgba(20, 10, 10, 0.5), transparent);\n  border-radius: 0 8px 8px 0;\n  white-space: pre-wrap; word-wrap: break-word;\n}\n</style>\n<div class=\"k-scene-wrap\">\n  <div class=\"k-single\">\n    <div class=\"k-line\"></div>\n    <div class=\"k-emblem\"></div>\n    <div class=\"k-type\">$1 <span style=\"color:#523939; margin: 0 6px;\">|</span> <span class=\"k-desc\">$2</span></div>\n    <div class=\"k-emblem\"></div>\n    <div class=\"k-line\"></div>\n  </div>\n  <div class=\"k-scene-body\">$3</div>\n</div>",
