{
    "id": "19557c07-79f9-4a8a-8ad5-a375fcfc5812",
    "scriptName": "[BB] transitions single",
    "findRegex": "/※([A-Za-zА-Яа-яЁё\\s]+?)\\s*:\\s*(.*?)※([\\s\\S]*?)※\\/\\s*\\1\\s*※/g",
    "replaceString": "<style>\n@keyframes vnFadeIn { from { opacity: 0; transform: translateY(15px); filter: blur(4px); } to { opacity: 1; transform: translateY(0); filter: blur(0); } }\n@keyframes vnGlow { 0%, 100% { box-shadow: 0 0 8px rgba(255,255,255,0.1); } 50% { box-shadow: 0 0 16px rgba(255,255,255,0.3); } }\n.vn-wrap { margin: 28px 0; width: 100%; animation: vnFadeIn 0.8s cubic-bezier(0.25, 1, 0.5, 1) forwards; }\n.vn-head { display: flex; align-items: center; justify-content: center; gap: 16px; margin-bottom: 16px; font-family: 'Georgia', serif; text-transform: uppercase; letter-spacing: 3px; }\n.vn-line { flex-grow: 1; height: 1px; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent); }\n.vn-diamond { width: 6px; height: 6px; transform: rotate(45deg); border: 1px solid rgba(255,255,255,0.6); background: rgba(255,255,255,0.1); animation: vnGlow 4s infinite ease-in-out; }\n.vn-type { color: #f3f4f6; font-weight: bold; text-shadow: 0 2px 4px rgba(0,0,0,0.5); }\n.vn-theme { color: #d1d5db; font-size: 0.85em; opacity: 0.8; }\n.vn-body { padding: 16px 24px; color: #f3f4f6; font-size: 1.05em; line-height: 1.65; font-family: 'Georgia', serif; background: rgba(20, 20, 25, 0.35); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.08); border-left: 3px solid rgba(253, 224, 71, 0.5); border-radius: 4px 12px 12px 4px; box-shadow: 0 8px 32px 0 rgba(0,0,0,0.3); white-space: pre-wrap; word-wrap: break-word; }\n</style>\n<div class=\"vn-wrap\">\n  <div class=\"vn-head\">\n    <div class=\"vn-line\"></div><div class=\"vn-diamond\"></div>\n    <div class=\"vn-type\">$1 <span style=\"color:rgba(255,255,255,0.3); margin: 0 8px;\">|</span> <span class=\"vn-theme\">$2</span></div>\n    <div class=\"vn-diamond\"></div><div class=\"vn-line\"></div>\n  </div>\n  <div class=\"vn-body\">$3</div>\n</div>",
    "trimStrings": [],
    "placement": [
        1,
        2,
        6
    ],
    "disabled": false,
