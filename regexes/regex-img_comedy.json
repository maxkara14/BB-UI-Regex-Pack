    "scriptName": "img comedy",
    "findRegex": "/::IMG_COMEDY_START::\\s*(?:Image:\\s*(<img[^>]+>)\\s*)?(?:Caption:\\s*([^\\n]*)\\s*)?[\\s\\S]*?::IMG_COMEDY_END::/g",
    "replaceString": "<style>\n@keyframes kg-com-jump { 0%, 100% { transform: translateY(0) scale(1) rotate(-1deg); } 50% { transform: translateY(-6px) scale(1.02) rotate(2deg); } }\n@keyframes kg-com-spark { 0%, 100% { opacity: 0; transform: scale(0.5) rotate(0deg); } 50% { opacity: 1; transform: scale(1.2) rotate(90deg); } }\n@keyframes kg-com-shockwave { 0% { width: 0; height: 0; border-width: 40px; opacity: 1; } 100% { width: 500px; height: 500px; border-width: 0; opacity: 0; } }\n\n.kg-card-com { max-width: 440px; margin: 25px auto; perspective: 1200px; cursor: pointer; animation: kg-com-jump 2s infinite cubic-bezier(0.28, 0.84, 0.42, 1); }\n.kg-inner-com { display: grid; width: 100%; min-height: 250px; transform-style: preserve-3d; transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1); }\n.kg-card-com:hover .kg-inner-com { transform: rotateY(180deg); }\n\n.kg-front-com, .kg-back-com { grid-area: 1 / 1; backface-visibility: hidden; border-radius: 12px; border: 4px solid #111; }\n.kg-front-com { background: repeating-linear-gradient(45deg, #fde047, #fde047 15px, #fef08a 15px, #fef08a 30px); display: flex; align-items: center; justify-content: center; box-shadow: 8px 8px 0 #fbbf24; overflow: hidden; position: relative; }\n\n/* Аниме-искра на чистом CSS */\n.kg-com-star { position: absolute; top: 15%; left: 15%; width: 6px; height: 50px; background: #fff; border-radius: 50%; box-shadow: 0 0 15px #fff, 0 0 20px #fbbf24; animation: kg-com-spark 1.5s infinite; }\n.kg-com-star::after { content: ''; position: absolute; top: 22px; left: -22px; width: 50px; height: 6px; background: #fff; border-radius: 50%; box-shadow: 0 0 15px #fff, 0 0 20px #fbbf24; }\n\n/* Центральный текст */\n.kg-com-title { background: #111; color: #fff; padding: 10px 20px; font-family: 'Comic Sans MS', sans-serif; font-weight: 900; font-size: 22px; letter-spacing: 2px; border-radius: 8px; transform: rotate(-10deg); box-shadow: 4px 4px 0 #fff; z-index: 2; position: relative; }\n\n.kg-back-com { transform: rotateY(180deg); background: #fff; padding: 12px; display: flex; flex-direction: column; box-shadow: -8px 8px 0 #fbbf24; position: relative; overflow: hidden; }\n.kg-back-com img { width: 100%; height: auto; border-bottom: 4px solid #111; border-radius: 4px; display: block; z-index: 2; position: relative; }\n.kg-cap-com { padding-top: 12px; text-align: center; font-family: 'Comic Sans MS', sans-serif; font-weight: 800; color: #111; font-size: 15px; text-transform: uppercase; z-index: 2; }\n\n/* Ударная волна на чистом CSS */\n.kg-com-effect { position: absolute; inset: 0; pointer-events: none; z-index: 3; display: flex; align-items: center; justify-content: center; }\n.kg-card-com:hover .kg-com-effect::before { content: ''; position: absolute; border-radius: 50%; border: dashed #fbbf24; animation: kg-com-shockwave 0.5s cubic-bezier(0.1, 0.8, 0.3, 1) forwards; }\n.kg-card-com:hover .kg-com-effect::after { content: ''; position: absolute; border-radius: 50%; border: solid #ef4444; animation: kg-com-shockwave 0.6s cubic-bezier(0.1, 0.8, 0.3, 1) 0.1s forwards; }\n</style>\n\n<div class=\"kg-card-com\">\n  <div class=\"kg-inner-com\">\n    <div class=\"kg-front-com\">\n      <div class=\"kg-com-star\"></div>\n      <div class=\"kg-com-title\">SUDDENLY!</div>\n    </div>\n    <div class=\"kg-back-com\">\n      $1\n      <div class=\"kg-com-effect\"></div>\n      <div class=\"kg-cap-com\">$2</div>\n    </div>\n  </div>\n</div>",
    "trimStrings": [],
