x; background:rgba(0,0,0,0.5); border-radius:3px; }\n.kg-n-fill { height:100%; border-radius:3px; }\n.kg-w-gear { background:rgba(20,15,20,0.8); border-radius:20px; padding:16px; border:1px solid rgba(255,255,255,0.05); display:grid; grid-template-columns:1fr 1fr; gap:8px; }\n.kg-g-title { grid-column:1/-1; font-size:11px; font-weight:800; color:#d4af37; text-transform:uppercase; border-bottom:1px solid rgba(255,255,255,0.05); padding-bottom:6px; margin-bottom:4px; text-align:center; }\n.kg-g-item { background:rgba(20,15,15,0.9); padding:10px; border-radius:6px; border-left:2px solid #3b82f6; display:flex; flex-direction:column; min-width:0; transition:all 0.2s ease; }\n.kg-g-item:hover { transform:translateY(-2px); box-shadow:0 4px 10px rgba(0,0,0,0.4); border-color:#8b5cf6; }\n.kg-g-label { font-size:9px; font-weight:800; color:#93c5fd; text-transform:uppercase; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }\n.kg-g-val { font-size:11px; margin-top:4px; line-height:1.3; overflow-wrap:break-word; word-wrap:break-word; hyphens:auto; }\n.kg-news-wrap { padding:15px; display:flex; flex-direction:column; gap:15px; flex:1; }\n.kg-w-news { background:rgba(20,15,20,0.8); border-radius:20px; padding:16px; border:1px solid rgba(255,255,255,0.05); display:flex; flex-direction:column; gap:14px; }\n.kg-nw-title { font-size:11px; font-weight:800; color:#fca5a5; text-transform:uppercase; border-bottom:1px dashed #3f2c2c; padding-bottom:6px; }\n.kg-nw-item { border-left:2px solid #d4af37; padding-left:10px; transition:all 0.3s ease; position:relative; overflow:hidden; }\n.kg-nw-item::before { content:''; position:absolute; top:0; left:0; width:100%; height:100%; background:linear-gradient(90deg, rgba(212,175,55,0.05), transparent); pointer-events:none; opacity:0; transition:opacity 0.3s ease; }\n.kg-nw-item:hover { transform:translateX(4px); }\n.kg-nw-item:hover::before { opacity:1; }\n.kg-nw-meta { font-size:10px; font-weight:800; color:#d4af37; text-transform:upp