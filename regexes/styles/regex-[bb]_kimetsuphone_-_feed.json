    "replaceString": "<style>\n@keyframes battShine { 0% { left: -20px; } 20%, 100% { left: 100%; } }\n@keyframes redBlink { 0%, 90%, 100% { background: #050505; box-shadow: inset 0 0 4px rgba(255,255,255,0.15); } 95% { background: #ef4444; box-shadow: 0 0 8px #ef4444; } }\n@keyframes ringBell { 0%, 80%, 100% { transform: rotate(0); filter: blur(0); } 82%, 86%, 90%, 94%, 98% { transform: rotate(-20deg); filter: blur(0.5px) drop-shadow(2px 0 0 rgba(252,165,165,0.6)); } 84%, 88%, 92%, 96% { transform: rotate(20deg); filter: blur(0.5px) drop-shadow(-2px 0 0 rgba(252,165,165,0.6)); } }\n@keyframes kgPulse { 0%,100%{opacity:0.5; transform:translateY(0);} 50%{opacity:1; transform:translateY(-5px);} }\n@keyframes gemPulse { 0%, 100% { box-shadow: 0 0 10px var(--c, #d4af37), inset 0 0 5px var(--c, #d4af37); transform: scale(1); } 50% { box-shadow: 0 0 25px var(--c, #d4af37), inset 0 0 12px var(--c, #d4af37); transform: scale(1.05); filter: brightness(1.2); } }\n@keyframes tsubaSpin { 100% { transform: translate(-50%, -50%) rotate(360deg); } }\n.kg-smart { position:relative; width:340px; height:640px; margin:20px auto; background:#070709; border-radius:42px; border:8px solid #1a1a1e; box-shadow:0 25px 60px rgba(0,0,0,0.8); overflow:hidden; font-family:-apple-system,sans-serif; color:#fff; user-select:none; }\n.kg-chk { display:none; }\n.kg-screen { position:absolute; inset:0; overflow:hidden; }\n.kg-scroll { overflow-y:auto; scrollbar-width:none; -ms-overflow-style:none; }\n.kg-scroll::-webkit-scrollbar { display:none; }\n.kg-topbar { position:absolute; top:0; left:0; right:0; height:45px; display:flex; justify-content:space-between; align-items:center; padding:0 22px; z-index:100; font-size:12px; font-weight:700; text-shadow:0 1px 3px rgba(0,0,0,0.8); pointer-events:none; }\n.kg-notch { position:absolute; top:0; left:50%; transform:translateX(-50%); width:110px; height:28px; background:#000; border-radius:0 0 14px 14px; display:flex; justify-content:center; align-items:cent