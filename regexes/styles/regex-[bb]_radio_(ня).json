    "findRegex": "/::RADIO_START::[\\s\\S]*?Comment:\\s*(?:<br[^>]*>|<\\/?p[^>]*>|\\s)*([\\s\\S]*?)(?:<br[^>]*>|<\\/?p[^>]*>|\\s)*::RADIO_END::/g",
    "replaceString": "<style>\n@keyframes eqBounce { 0% { height: 4px; } 100% { height: 24px; } }\n@keyframes slideMarquee { 0% { transform: translateX(100%); } 100% { transform: translateX(-100%); } }\n@keyframes pulseLive { 0%, 100% { box-shadow: 0 0 5px rgba(236,72,153,0.4); } 50% { box-shadow: 0 0 15px rgba(236,72,153,0.9); } }\n@keyframes blinkDot { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }\n@keyframes flowerDance { 0%, 100% { transform: rotate(0deg) scale(1); } 25% { transform: rotate(15deg) scale(1.1); } 75% { transform: rotate(-15deg) scale(1.1); } }\n\n.kr-wrap { margin: 24px 0; font-family: 'Georgia', -apple-system, sans-serif; width: 100%; box-sizing: border-box; background: #0f060b; border: 1px solid #4a2c3a; border-left: 4px solid #ec4899; border-radius: 8px; box-shadow: 0 6px 20px rgba(0,0,0,0.6); transition: box-shadow 0.3s ease; overflow: hidden; }\n.kr-wrap:hover { box-shadow: 0 8px 25px rgba(236,72,153,0.15); }\n\n.kr-label { display: block; cursor: pointer; margin: 0; padding: 0; }\n.kr-summary { background: linear-gradient(180deg, #1f1018, #120a10); padding: 14px 20px; display: flex; align-items: center; justify-content: space-between; color: #22d3ee; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; position: relative; z-index: 2; transition: all 0.3s ease; border-bottom: 1px solid transparent; user-select: none; }\n.kr-label:hover .kr-summary { background: linear-gradient(180deg, #2a1523, #1a0d14); }\n\n/* Магия Checkbox Hack + CSS Grid для идеальной анимации туда-обратно */\n.kr-wrap:has(.kr-toggle:checked) .kr-summary { border-bottom: 1px solid #4a2c3a; background: #120a10; box-shadow: 0 4px 15px rgba(0,0,0,0.8); }\n.kr-wrap:has(.kr-toggle:checked) .kr-grid-wrapper { grid-template-rows: 1fr; opacity: 1; transform: translateY(0); }\n\n.kr-grid-wrapper { display: grid; grid-template-rows: 0fr; opacity: 0; transform: translateY(-15px); transition: grid-template-rows 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.3s ease, transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1); position: relative; z-index: 1; }\n.kr-grid-inner { overflow: hidden; }\n\n.l-flower { display: inline-block; animation: flowerDance 2.5s ease-in-out infinite; transform-origin: center; margin-right: 4px; filter: drop-shadow(0 0 4px rgba(236,72,153,0.5)); }\n.l-live-badge { display: flex; align-items: center; gap: 8px; background: rgba(236,72,153,0.15); border: 1px solid rgba(236,72,153,0.5); padding: 4px 12px; border-radius: 4px; color: #fbcfe8; font-size: 0.75em; font-family: -apple-system, sans-serif; letter-spacing: 1px; font-weight: bold; animation: pulseLive 2s infinite ease-in-out; }\n.l-live-dot { width: 8px; height: 8px; background: #f472b6; border-radius: 50%; box-shadow: 0 0 8px #f472b6; animation: blinkDot 1s infinite; }\n\n.l-podcast-body { background: linear-gradient(180deg, #1b0c14, #0a0407); padding: 24px 20px 20px 20px; display: flex; flex-direction: column; gap: 20px; position: relative; z-index: 1; box-shadow: inset 0 10px 20px rgba(0,0,0,0.6); }\n.l-podcast-body::before { content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-image: radial-gradient(rgba(34,211,238,0.05) 1px, transparent 1px); background-size: 6px 6px; pointer-events: none; }\n\n.l-top-section { display: flex; gap: 16px; align-items: stretch; position: relative; z-index: 1; }\n.l-avatar { width: 90px; height: 90px; flex-shrink: 0; background: #0a0a0c; border-radius: 6px; border: 1px solid #4a2c3a; position: relative; box-shadow: 0 4px 15px rgba(0,0,0,0.8); overflow: hidden; }\n.l-avatar-image { width: 100%; height: 100%; background-image: url('https://thumbs2.imgbox.com/df/5e/uzyNpFYJ_t.png'); background-size: cover; background-position: center; background-repeat: no-repeat; filter: contrast(1.1) brightness(1.1); }\n.l-speech-bubble { background: #1e0f18; border: 1px solid #4a2c3a; border-radius: 8px; padding: 16px 20px; color: #fdf2f8; font-size: 0.95em; line-height: 1.6; font-style: italic; flex-grow: 1; position: relative; box-shadow: inset 0 0 15px rgba(0,0,0,0.5), 0 4px 10px rgba(0,0,0,0.3); white-space: pre-wrap; word-wrap: break-word; }\n.l-speech-bubble p, .l-speech-bubble div, .l-speech-bubble span, .l-speech-bubble blockquote { display: inline !important; margin: 0 !important; padding: 0 !important; }\n.l-speech-bubble > br { display: none !important; }\n\n.l-player { background: #0c0508; border: 1px solid #3a1c2a; border-radius: 6px; padding: 14px 20px; display: flex; align-items: center; justify-content: space-between; gap: 20px; position: relative; z-index: 1; border-left: 3px solid #22d3ee; box-shadow: inset 0 0 20px rgba(0,0,0,0.8); }\n.l-track-info { flex-grow: 1; overflow: hidden; display: flex; flex-direction: column; gap: 8px; }\n.l-now-playing-row { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 1px solid #2a1523; padding-bottom: 6px; margin-bottom: 2px; }\n.l-now-playing { font-size: 0.65em; color: #fbcfe8; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; font-family: -apple-system, sans-serif; }\n.l-freq { font-size: 0.6em; color: #22d3ee; font-family: monospace; letter-spacing: 1px; font-weight: bold; }\n.l-marquee { width: 100%; overflow: hidden; position: relative; padding: 2px 0; -webkit-mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent); mask-image: linear-gradient(90deg, transparent, #000 5%, #000 95%, transparent); }\n.l-marquee span { display: inline-block; white-space: nowrap; animation: slideMarquee 15s linear infinite; color: #a5f3fc; font-weight: bold; font-size: 0.85em; letter-spacing: 1.5px; font-family: -apple-system, sans-serif; }\n\n.l-eq-box { background: #080305; border: 1px solid #2a1523; border-radius: 4px; padding: 8px 10px; box-shadow: inset 0 0 10px rgba(0,0,0,0.9); height: 36px; display: flex; align-items: center; justify-content: center; }\n.l-eq { display: flex; align-items: flex-end; gap: 4px; height: 28px; }\n.l-eq span { display: block; width: 4px; background: linear-gradient(to top, #22d3ee, #ec4899); border-radius: 1px; animation: eqBounce 0.5s alternate infinite ease-in-out; }\n.l-eq span:nth-child(1) { animation-delay: 0.1s; } .l-eq span:nth-child(2) { animation-delay: 0.3s; } .l-eq span:nth-child(3) { animation-delay: 0.0s; } .l-eq span:nth-child(4) { animation-delay: 0.4s; } .l-eq span:nth-child(5) { animation-delay: 0.2s; }\n\n.l-audio-container { margin-top: 4px; width: 100%; max-width: 320px; }\naudio.l-audio-player { width: 100%; height: 32px; display: block; outline: none !important; box-shadow: none !important; color-scheme: dark; }\naudio.l-audio-player::-webkit-media-controls-enclosure, audio.l-audio-player::-webkit-media-controls-panel { background: #1a0d14 !important; border: 1px solid #3a1c2a; border-radius: 4px; }\naudio.l-audio-player::-webkit-media-controls-play-button, audio.l-audio-player::-webkit-media-controls-mute-button, audio.l-audio-player::-webkit-media-controls-volume-slider, audio.l-audio-player::-webkit-media-controls-current-time-display, audio.l-audio-player::-webkit-media-controls-time-remaining-display { cursor: pointer; filter: sepia(1) saturate(5) hue-rotate(290deg) brightness(1.2) !important; }\naudio.l-audio-player::-webkit-media-controls-timeline { display: none !important; }\n</style>\n<div class=\"kr-wrap\"><label class=\"kr-label\"><input type=\"checkbox\" class=\"kr-toggle\" style=\"display:none;\"><div class=\"kr-summary\"><span><span class=\"l-flower\">🌸</span> LYCORIS FM</span><div class=\"l-live-badge\"><div class=\"l-live-dot\"></div> LIVE</div></div></label><div class=\"kr-grid-wrapper\"><div class=\"kr-grid-inner\"><div class=\"l-podcast-body\"><div class=\"l-top-section\"><div class=\"l-avatar\"><div class=\"l-avatar-image\"></div></div><div class=\"l-speech-bubble\">$1</div></div><div class=\"l-player\"><div class=\"l-track-info\"><div class=\"l-now-playing-row\"><span class=\"l-now-playing\">ANIME BROADCAST</span><span class=\"l-freq\">FM 87.5 // OTAKU</span></div><div class=\"l-marquee\"><span>♪ 87.5 LYCORIS FM • 24/7 ANIME HITS ♪ 87.5 LYCORIS FM • OTAKU MIX ♪</span></div><div class=\"l-audio-container\"><audio class=\"l-audio-player\" controls preload=\"none\" src=\"http://pool.anison.fm:9000/AniSonFM(320)?nocache=0.9834540412142996\"></audio></div></div><div class=\"l-eq-box\"><div class=\"l-eq\"><span></span><span></span><span></span><span></span><span></span></div></div></div></div></div></div></div>",
