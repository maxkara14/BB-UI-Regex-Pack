    "replaceString": "<style>\n.sil-clock-wrap { display: flex; align-items: center; gap: 20px; background: linear-gradient(135deg, rgba(20, 25, 30, 0.8), rgba(10, 12, 15, 0.9)); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); border: 1px solid rgba(148, 163, 184, 0.15); border-left: 3px solid #94a3b8; border-right: 3px solid #94a3b8; border-radius: 4px; padding: 12px 24px; margin: 24px 0; box-shadow: 0 4px 20px rgba(0,0,0,0.5), inset 0 0 15px rgba(148,163,184,0.05); font-family: 'Georgia', serif; flex-wrap: wrap; position: relative; overflow: hidden; }\n.sil-clock-wrap::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 1px; background: linear-gradient(90deg, transparent, rgba(148, 163, 184, 0.5), transparent); }\n.sil-time { font-size: 1.8em; color: #f8fafc; letter-spacing: 2px; font-weight: 300; text-shadow: 0 0 10px rgba(255,255,255,0.2); }\n.sil-div { width: 1px; height: 36px; background: linear-gradient(to bottom, transparent, rgba(148,163,184,0.4), transparent); }\n.sil-info { display: flex; flex-direction: column; gap: 4px; }\n.sil-loc { font-size: 0.85em; font-weight: bold; color: #bae6fd; letter-spacing: 2px; text-transform: uppercase; }\n.sil-date { font-size: 0.9em; color: #cbd5e1; opacity: 0.9; }\n.sil-weather { font-size: 0.9em; color: #94a3b8; }\n.sil-icon { font-size: 1.2em; filter: drop-shadow(0 0 4px rgba(186,230,253,0.4)); }\n</style>\n<div class=\"sil-clock-wrap\">\n<div class=\"sil-time\">$5</div>\n<div class=\"sil-div\"></div>\n<div class=\"sil-info\">\n<div class=\"sil-loc\">$3</div>\n<div class=\"sil-date\">$1 &nbsp;|&nbsp; $2</div>\n</div>\n<div class=\"sil-div\"></div>\n<div class=\"sil-weather\"><span class=\"sil-icon\">$4</span></div>\n</div>",
